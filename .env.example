# Generic LLM settings used by Python scripts.
#
# OpenRouter example:
# LLM_PROVIDER=openai_compatible
# LLM_API_KEY=sk-or-v1-your-openrouter-key-here
# LLM_MODEL=openrouter/free
# LLM_BASE_URL=https://openrouter.ai/api/v1
#
# OpenAI example:
# LLM_PROVIDER=openai_compatible
# LLM_API_KEY=sk-your-openai-key-here
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1
#
# Anthropic / Claude example:
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-your-anthropic-key-here
# LLM_MODEL=claude-3-5-haiku-latest
#
# Google AI Studio / Gemini example:
# LLM_PROVIDER=google
# LLM_API_KEY=your-google-ai-studio-key-here
# LLM_MODEL=gemini-2.5-flash
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta

LLM_PROVIDER=openai_compatible
LLM_API_KEY=your-real-api-key-here
LLM_MODEL=openrouter/free
LLM_BASE_URL=https://openrouter.ai/api/v1

# Generation controls.
MAX_TOPICS=100
LLM_REQUEST_DELAY_SECONDS=15
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=60
MIN_OUTPUT_WORDS=80

# Optional metadata for OpenRouter rankings/analytics.
LLM_SITE_URL=https://github.com/NabilM5/AI_Detection
LLM_APP_NAME=AI Detection Medical Dataset Generator
